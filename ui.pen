                        },
                        {
                          "type": "text",
                          "id": "4mwPk",
                          "fill": "#94A3B8",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "A method and system for real-time adaptive data compression comprising: receiving input data streams, analyzing network bandwidth conditions, applying variable compression ratios based on determined conditions, and transmitting compressed data packets optimized for current network state.",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 13
                        }
                      ]
