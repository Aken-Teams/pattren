                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "nYgEp",
                          "fill": "#94A3B8",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Conventional data transmission systems rely on static compression algorithms that fail to adapt to dynamic network conditions, resulting in suboptimal throughput and increased latency under variable bandwidth scenarios.",
                          "lineHeight": 1.4,
                          "fontFamily": "Inter",
                          "fontSize": 13
                        }
                      ]
                    },
