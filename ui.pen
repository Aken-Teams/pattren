                            {
                              "type": "text",
                              "id": "jvTXG",
                              "fill": "#64748B",
                              "content": "摘要",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 10,
                              "fontWeight": "600",
                              "letterSpacing": 2
                            },
                            {
                              "type": "icon_font",
                              "id": "H8ETJ",
                              "width": 14,
