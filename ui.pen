                            {
                              "type": "text",
                              "id": "Uh07a",
                              "fill": "#64748B",
                              "content": "背景技術",
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 10,
                              "fontWeight": "600",
                              "letterSpacing": 2
                            },
                            {
                              "type": "icon_font",
                              "id": "AQyHa",
                              "width": 14,
                              "height": 14,
                              "iconFontName": "copy",
